<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="CrashlessLLM.AvaloniaDemo.MainWindow"
        Title="CrashlessLLM Avalonia Demo"
        Width="800" Height="600">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="8">
      <TextBlock Text="Model path (.gguf)" FontWeight="Bold"/>
      <TextBox x:Name="ModelPathTextBox"
               Watermark="/path/to/model.gguf"
               Text="/Users/mohammedhossam/.ollama/models/blobs/sha256-71166bc6f9d2a95eb8d72e28776fe390a663bf636bc4bdbde932ffeff3aad58d"/>

      <TextBlock Text="Prompt" FontWeight="Bold"/>
      <TextBox x:Name="PromptTextBox"
               Watermark="Say hello."
               Text="Say hello in one sentence."
               AcceptsReturn="True"
               Height="80"/>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button x:Name="GenerateButton" Content="Generate" Width="120"/>
        <Button x:Name="CancelButton" Content="Cancel" Width="120" IsEnabled="False"/>
      </StackPanel>
    </StackPanel>

    <TextBlock DockPanel.Dock="Top" Text="Output" FontWeight="Bold" Margin="0,12,0,4"/>
    <Border BorderBrush="Gray" BorderThickness="1">
      <ScrollViewer>
        <TextBox x:Name="OutputTextBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
      </ScrollViewer>
    </Border>
  </DockPanel>
</Window>
